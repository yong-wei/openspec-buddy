# Lite default: the only required setting.
OPENSPEC_BUDDY_BASE_BRANCH=integration

# Full-only and manual Buddy configuration. `openspec-buddy init --full`
# writes these values; an existing full file remains a valid lite superset.
OPENSPEC_BUDDY_RELEASE_BRANCH=main
OPENSPEC_BUDDY_PROJECT_OWNER=github-owner-or-org
OPENSPEC_BUDDY_PROJECT_NUMBER=1
OPENSPEC_BUDDY_PROJECT_TITLE="OpenSpec Work"

# Full-only CI policy. Keep false unless the repository intentionally has no CI.
OPENSPEC_BUDDY_ALLOW_NO_CI=false

# Full-only/manual review request. Lite always uses:
# @codex review 中文回复，即使没有重大问题也必须给出显式回复
# OPENSPEC_BUDDY_PR_REVIEW_REQUEST="@codex review 中文回复，即使没有重大问题也必须给出显式回复"
