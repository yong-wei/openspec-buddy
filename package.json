{
  "name": "openspec-buddy",
  "version": "0.22.0",
  "description": "Versioned npm distribution for the OpenSpec Buddy agent skills.",
  "type": "module",
  "bin": {
    "openspec-buddy": "bin/openspec-buddy.mjs"
  },
  "files": [
    "bin",
    "src",
    "skills",
    "test",
    "README.md",
    ".env.openspec-buddy.example",
    "LICENSE"
  ],
  "scripts": {
    "test": "node test/run-all-tests.mjs full",
    "test:fast": "node test/run-all-tests.mjs fast",
    "test:helpers": "node test/run-all-tests.mjs helpers",
    "test:full": "node test/run-all-tests.mjs full",
    "check": "npm run test:full && npm pack --dry-run",
    "pack:local": "npm pack",
    "publish:public": "npm publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yong-wei/openspec-buddy.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "openspec",
    "agent-skills",
    "codex",
    "github-issues"
  ],
  "author": "Yong-Wei Zhang",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yong-wei/openspec-buddy/issues"
  },
  "homepage": "https://github.com/yong-wei/openspec-buddy#readme",
  "engines": {
    "node": ">=18"
  }
}
